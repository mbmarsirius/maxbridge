# ══════════════════════════════════════════════════════════════════
# Maxbridge — top-level .gitignore
# ══════════════════════════════════════════════════════════════════

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?

# Editors
.idea/
.vscode/
*.swp
*.swo
*~

# ───────────── Secrets — NEVER commit ─────────────
.env
.env.*
*.local
*.local.json
*.local.toml
*.local.ts
*.keys.json
*.keys.local.json
*-keys.json
*.keys.local
.secrets.env
.secrets/*

# Specific known secret-bearing files in this repo
worker/maxbridge-jwt.keys.local.json
worker/.stripe-ids.local
src-tauri/.env.signing

# Certificates / keys
*.pem
!server/license/pubkey.pem
*.key
*.crt
*.p12
*.mobileprovision

# ───────────── Node ─────────────
node_modules/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tsbuildinfo

# ───────────── Rust (Tauri) ─────────────
target/
*.rs.bk
src-tauri/target/
src-tauri/gen/schemas/

# ───────────── Build artifacts ─────────────
dist/
dist-*/
build/
out/
*.dmg
*.app
*.appimage

# ───────────── Cloudflare Wrangler ─────────────
.wrangler/
wrangler.log
.dev.vars

# ───────────── Logs + tmp ─────────────
*.log
logs/
.turbo/
.next/
.vite/
coverage/
.nyc_output/

# Tauri-specific backups
*.bak
*.bak-*
