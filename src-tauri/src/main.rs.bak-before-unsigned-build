#![cfg_attr(not(debug_assertions), windows_subsystem = "windows")]

use serde::Serialize;

#[derive(Serialize)]
struct AppInfo {
    name: &'static str,
    version: &'static str,
    proxy_endpoint: &'static str,
    status_source: &'static str,
    notes: &'static str,
}

#[tauri::command]
fn get_app_info() -> AppInfo {
    AppInfo {
        name: "LocalClaw",
        version: "0.1.0-alpha.1",
        proxy_endpoint: "http://127.0.0.1:7423",
        status_source: "http://127.0.0.1:7423/v1/status",
        notes: "Live vs stub, key presence, and default model are served by the LocalClaw proxy at status_source. The Tauri shell never asserts those values itself.",
    }
}

fn main() {
    tauri::Builder::default()
        .invoke_handler(tauri::generate_handler![get_app_info])
        .run(tauri::generate_context!())
        .expect("error while running LocalClaw");
}
